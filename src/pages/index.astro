---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/home/Hero.astro";
import Values from "../components/home/Values.astro";
import History from "../components/home/History.astro";
import Menu from "../components/home/Menu.astro";
import VisitUs from "../components/VisitUs.astro";
import { smoothTransition } from "../utils/transitions";
---

<Layout
  title="Raíces Café | Café de Especialidad en Marinilla"
  description="Descubre Raíces Café en Marinilla, Antioquia. Café de especialidad, preparaciones artesanales y un espacio que honra nuestras raíces."
  canonical="/"
>
  <Header />
  <main transition:animate={smoothTransition}>
    <Hero />
    <Values />
    <History />
    <Menu />
    <VisitUs />
  </main>
</Layout>
