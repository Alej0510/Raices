---
import { ViewTransitions } from 'astro:transitions';
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageAlt?: string;
  canonical?: string;
  breadcrumbs?: { name: string; item: string }[];
}

const {
  title = "Raíces Café",
  description = "Café de especialidad en Marinilla, Antioquia. Un homenaje a la tierra, la tradición y cada grano cultivado con pasión.",
  image = "/logo.png",
  imageWidth = 1045,
  imageHeight = 411,
  imageAlt = "Logo de Raíces Café en Marinilla, Antioquia",
  canonical,
  breadcrumbs,
} = Astro.props;

const siteUrl = "https://raices-cafe.vercel.app";
const pathname = Astro.url.pathname === "/" ? "" : Astro.url.pathname;
const pagePath = canonical === "/" ? "" : (canonical ?? pathname);
const pageUrl = `${siteUrl}${pagePath}`;
const absoluteImage = `${siteUrl}${image}`;

const localBusiness = {
  "@type": "CafeOrCoffeeShop",
  name: "Raíces Café",
  description,
  image: `${siteUrl}/logo.png`,
  url: siteUrl,
  telephone: "+57-314-625-7790",
  email: "elmati@gmail.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Calle 12, Marinilla-Rionegro #45 46",
    addressLocality: "Marinilla",
    addressRegion: "Antioquia",
    addressCountry: "CO",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 6.1694209,
    longitude: -75.3496963,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "08:00",
      closes: "20:00",
    },
  ],
  priceRange: "$$",
  servesCuisine: "Café de especialidad",
  paymentAccepted: "Efectivo, tarjeta de crédito, tarjeta débito, transferencia",
  currenciesAccepted: "COP",
  sameAs: [],
};

const breadcrumbList = breadcrumbs && breadcrumbs.length > 0 ? {
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((crumb, index) => {
    const itemPath = crumb.item === "/" ? "" : crumb.item;
    return {
      "@type": "ListItem",
      position: index + 1,
      name: crumb.name,
      item: crumb.item.startsWith("http") ? crumb.item : `${siteUrl}${itemPath}`,
    };
  }),
} : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": breadcrumbList ? [localBusiness, breadcrumbList] : [localBusiness],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#6b823e" />
    <meta name="author" content="Raíces Café" />
    <meta name="geo.region" content="CO-ANT" />
    <meta name="geo.placename" content="Marinilla, Antioquia" />
    <meta name="geo.position" content="6.1694209;-75.3496963" />
    <meta name="ICBM" content="6.1694209, -75.3496963" />

    <link rel="canonical" href={pageUrl} />
    <link rel="alternate" hreflang="es" href={pageUrl} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Raíces Café" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={String(imageWidth)} />
    <meta property="og:image:height" content={String(imageHeight)} />
    <meta property="og:image:alt" content={imageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.google.com" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <ViewTransitions />
  </head>
  <body>
    <slot />

    <!-- WhatsApp Bubble -->
    <a
      href="https://wa.me/573146257790?text=Hola%20quiero%20información%20acerca%20de%20Raíces%20Café"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 bg-green-cafe text-white p-4 rounded-full shadow-lg hover:bg-[#4a5e28] transition-all duration-300 group"
      aria-label="Contactar por WhatsApp"
      transition:persist="whatsapp-bubble"
    >
      <svg fill="none" viewBox="0 0 360 362" class="w-6 h-6">
        <path
          fill="currentColor"
          fill-rule="evenodd"
          d="M307.546 52.566C273.709 18.684 228.706.017 180.756 0 81.951 0 1.538 80.404 1.504 179.235c-.017 31.594 8.242 62.432 23.928 89.609L0 361.736l95.024-24.925c26.179 14.285 55.659 21.805 85.655 21.814h.077c98.788 0 179.21-80.413 179.244-179.244.017-47.898-18.608-92.926-52.454-126.807v-.008Zm-126.79 275.788h-.06c-26.73-.008-52.952-7.194-75.831-20.765l-5.44-3.231-56.391 14.791 15.05-54.981-3.542-5.638c-14.912-23.721-22.793-51.139-22.776-79.286.035-82.14 66.867-148.973 149.051-148.973 39.793.017 77.198 15.53 105.328 43.695 28.131 28.157 43.61 65.596 43.593 105.398-.035 82.149-66.867 148.982-148.982 148.982v.008Zm81.719-111.577c-4.478-2.243-26.497-13.073-30.606-14.568-4.108-1.496-7.09-2.243-10.073 2.243-2.982 4.487-11.568 14.577-14.181 17.559-2.613 2.991-5.226 3.361-9.704 1.117-4.477-2.243-18.908-6.97-36.02-22.226-13.313-11.878-22.304-26.54-24.916-31.027-2.613-4.486-.275-6.91 1.959-9.136 2.011-2.011 4.478-5.234 6.721-7.847 2.244-2.613 2.983-4.486 4.478-7.469 1.496-2.991.748-5.603-.369-7.847-1.118-2.243-10.073-24.289-13.812-33.253-3.636-8.732-7.331-7.546-10.073-7.692-2.613-.13-5.595-.155-8.586-.155-2.991 0-7.839 1.118-11.947 5.604-4.108 4.486-15.677 15.324-15.677 37.361s16.047 43.344 18.29 46.335c2.243 2.991 31.585 48.225 76.51 67.632 10.684 4.615 19.029 7.374 25.535 9.437 10.727 3.412 20.49 2.931 28.208 1.779 8.604-1.289 26.498-10.838 30.228-21.298 3.73-10.46 3.73-19.433 2.613-21.298-1.117-1.865-4.108-2.991-8.586-5.234l.008-.017Z"
          clip-rule="evenodd"></path>
      </svg>
    </a>
  </body>
</html>
