---
const MAP_IMG      = 'https://www.figma.com/api/mcp/asset/6ec2e62d-e304-44d4-a38a-9c14c1feb774';
const ICON_PIN     = 'https://www.figma.com/api/mcp/asset/96d7a57f-7328-492c-8d5d-94691804a714';
const ICON_ADDR    = 'https://www.figma.com/api/mcp/asset/3bfd476e-740e-418b-84ac-d276d7162ce7';
const ICON_CLOCK   = 'https://www.figma.com/api/mcp/asset/e64b6d2f-7dfe-41f0-9ed2-ae1f7d8a62a6';
const ICON_PHONE   = 'https://www.figma.com/api/mcp/asset/56dd41fd-3f60-4d0a-a636-4c514fbe4733';
const ICON_TW      = 'https://www.figma.com/api/mcp/asset/94fbac1f-7bf3-4ed5-bf53-3e0ad44a50e7';
const ICON_IG      = 'https://www.figma.com/api/mcp/asset/fa4a997d-7820-44ab-9bcd-4a94c36e1f13';

const contactItems = [
  {
    icon: ICON_ADDR,
    title: 'Dirección',
    lines: ['Calle 12, Marinilla-Rionegro #45 46, Marinilla, Antioquia'],
  },
  {
    icon: ICON_CLOCK,
    title: 'Horario',
    lines: ['Lunes - Sábado: 8:00 AM - 8:00 PM', 'Domingo: 9:00 AM - 6:00 PM'],
  },
  {
    icon: ICON_PHONE,
    title: 'Contacto',
    lines: ['+57 314 625 7790', 'elmati@gmail.com'],
  },
];
---

<section id="contacto" class="bg-stone-cafe px-8 py-16">
  <div class="max-w-[1280px] mx-auto flex flex-col gap-16">

    <!-- Grid -->
    <div class="flex gap-12 items-start">

      <!-- Info column -->
      <div class="flex-1 flex flex-col gap-8">
        <div>
          <h2 class="font-display text-3xl font-normal text-white mb-1">Visítanos</h2>
          <p class="text-warm text-base font-extralight">Te esperamos con el mejor café de Marinilla.</p>
        </div>

        <!-- Contact items -->
        <div class="flex flex-col gap-6">
          {contactItems.map(item => (
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0">
                <img src={item.icon} alt={item.title} class="w-5 h-5 object-contain" />
              </div>
              <div>
                <h4 class="text-white text-lg font-extralight leading-7">{item.title}</h4>
                {item.lines.map(line => (
                  <p class="text-warm text-base font-extralight leading-6">{line}</p>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Social links -->
        <div class="flex gap-4 pt-4">
          <a href="#" class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 transition-colors">
            <img src={ICON_TW} alt="Twitter" class="w-5 h-5 object-contain" />
          </a>
          <a href="#" class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 transition-colors">
            <img src={ICON_IG} alt="Instagram" class="w-5 h-5 object-contain" />
          </a>
        </div>
      </div>


      <div class="flex-1 h-[400px] rounded-2xl border-4 border-white/5 overflow-hidden relative
                  shadow-[0_10px_15px_-3px_rgba(0,0,0,0.1),0_4px_6px_-4px_rgba(0,0,0,0.1)]">

        <img
          src={MAP_IMG}
          alt="Mapa Marinilla, Antioquia"
          class="w-full h-full object-cover opacity-60 grayscale"
        />

        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                    bg-[rgba(85,107,47,0.9)] rounded-lg px-4 py-2 flex items-center gap-2
                    shadow-[0_10px_15px_-3px_rgba(0,0,0,0.1)]">
          <img src={ICON_PIN} alt="" class="w-3 h-3 object-contain" />
          <span class="text-white text-sm font-extralight">Aquí estamos</span>
        </div>

        <div class="absolute bottom-4 right-4 bg-white rounded-lg px-2 py-1
                    shadow-[0_1px_3px_rgba(0,0,0,0.1)] text-stone-cafe text-xs font-extralight">
          Map data ©2026
        </div>
      </div>

    </div>


    <div class="border-t border-white/10 pt-8 text-center text-sm text-warm font-extralight">
      © 2026 Raíces Café. Todos los derechos reservados. Marinilla, Antioquia.
    </div>

  </div>
</section>
