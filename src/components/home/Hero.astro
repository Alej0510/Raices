---
import { Image } from "astro:assets";
import hero from "/public/home/hero.png";
---

<section
  class="relative mx-4 mt-6 rounded-[2rem] overflow-hidden min-h-[480px] flex items-center justify-center sm:mx-6 sm:mt-8 sm:min-h-[580px] lg:mx-8 lg:mt-10 lg:min-h-[640px] shadow-2xl shadow-stone-cafe/20"
>
  <!-- Background image with Ken Burns -->
  <div class="absolute inset-0 overflow-hidden">
    <Image
      src={hero}
      alt="Ambiente acogedor de Raíces Café en Marinilla, Antioquia"
      class="w-full h-full object-cover opacity-90 animate-ken-burns"
      width={1920}
      height={1080}
      fetchpriority="high"
    />
  </div>

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-stone-cafe via-stone-cafe/60 to-black/20"
  >
  </div>

  <!-- Decorative blurred orbs -->
  <div
    class="absolute top-1/4 -left-20 w-72 h-72 bg-green-cafe/20 rounded-full blur-[100px] pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-1/4 -right-20 w-80 h-80 bg-cream/10 rounded-full blur-[100px] pointer-events-none"
  >
  </div>

  <!-- Content -->
  <div
    class="relative z-10 flex flex-col items-center gap-7 max-w-3xl px-6 py-16 text-center sm:py-24"
  >
    <!-- Title -->
    <h1
      class="font-display text-5xl font-normal italic text-white leading-[1.05] sm:text-7xl lg:text-8xl text-shadow"
    >
      El Sabor de{" "}
      <span class="italic text-white">Nuestras<br />Raíces</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="text-cream/90 text-lg leading-8 max-w-xl font-light sm:text-xl lg:text-2xl text-shadow-sm"
    >
      Café de especialidad en Marinilla, Antioquia.
      <br class="hidden sm:block" /> Un homenaje a la tierra, a la tradición y a cada
      grano cultivado con pasión.
    </p>

    <!-- Buttons -->
    <div class="flex flex-col w-full gap-4 pt-4 sm:w-auto sm:flex-row sm:gap-6">
      <a
        href="/menu"
        class="group flex items-center justify-center gap-3 bg-green-cafe text-white text-lg font-medium tracking-wide rounded-full px-10 py-4
               hover:bg-[#5a6e34] hover:shadow-[0_0_36px_rgba(107,130,62,0.65)] transform hover:-translate-y-1 transition-all duration-300"
      >
        <svg
          class="w-5 h-5 group-hover:scale-110 transition-transform duration-300"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"
          ></path>
          <rect x="9" y="3" width="6" height="4" rx="1"></rect>
        </svg>
        Ver Menú
      </a>
      <a
        href="#contacto"
        class="group flex items-center justify-center gap-2 text-white text-lg font-medium tracking-wide rounded-full px-10 py-4
               bg-white/10 border-2 border-white/40 backdrop-blur-md
               hover:bg-white/20 hover:border-white/60 transform hover:-translate-y-1 transition-all duration-300 shadow-lg"
      >
        Visítanos
        <svg
          class="w-4 h-4 group-hover:translate-y-0.5 transition-transform duration-300"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
