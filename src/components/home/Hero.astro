---
import { Image } from "astro:assets";
import hero from "/public/home/hero.png";
---

<section
  class="relative mx-4 mt-6 rounded-2xl overflow-hidden min-h-[420px] flex items-center justify-center sm:mx-6 sm:mt-10 sm:min-h-[520px] lg:mx-8 lg:mt-12 lg:min-h-[560px]"
>
  <!-- Background image -->
  <Image
    src={hero}
    alt="Café Raíces"
    class="absolute inset-0 w-full h-full object-cover opacity-90"
    width={1920}
    height={1080}
  />

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/30"
  >
  </div>

  <!-- Content -->
  <div
    class="relative z-10 flex flex-col items-center gap-6 max-w-3xl px-4 py-14 text-center sm:py-20"
  >
    <!-- Title -->
    <h1
      class="font-extrabold font-display text-4xl italic text-white leading-tight sm:text-6xl lg:text-7xl"
    >
      El Sabor de{" "}
      <span class="italic text-white">Nuestras<br />Raíces</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="text-white text-base leading-7 max-w-lg font-extralight sm:text-lg lg:text-xl"
    >
      Café de especialidad en Marinilla, Antioquia.
      <br /> Un homenaje a la tierra, a la tradición y a cada grano cultivado con
      pasión.
    </p>

    <!-- Buttons -->
    <div class="flex flex-col w-full gap-3 pt-4 sm:w-auto sm:flex-row sm:gap-4">
      <a
        href="/menu"
        class="flex items-center justify-center gap-2 bg-green-cafe text-white text-base font-extralight rounded-lg px-8 py-3
               shadow-[0_10px_15px_-3px_rgba(85,107,47,0.3),0_4px_6px_-4px_rgba(85,107,47,0.3)]
               hover:bg-[#4a5e28] transition-colors duration-200"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"
          ></path>
          <rect x="9" y="3" width="6" height="4" rx="1"></rect>
        </svg>
        Ver Menú
      </a>
      <a
        href="#contacto"
        class="flex items-center justify-center text-white text-base font-extralight rounded-lg px-8 py-3
               bg-white/10 border border-white/30 backdrop-blur-sm
               hover:bg-white/20 transition-colors duration-200"
      >
        Visítanos
      </a>
    </div>
  </div>
</section>
