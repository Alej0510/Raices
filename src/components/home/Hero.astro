---
import { Image } from "astro:assets";
import hero from "/public/home/hero.png";
---

<section
  class="relative mx-4 mt-6 rounded-2xl overflow-hidden min-h-[420px] flex items-center justify-center sm:mx-6 sm:mt-10 sm:min-h-[520px] lg:mx-8 lg:mt-12 lg:min-h-[560px]"
>
  <!-- Background image -->
  <Image
    src={hero}
    alt="Café Raíces"
    class="absolute inset-0 w-full h-full object-cover opacity-90"
    width={1920}
    height={1080}
  />

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/30"
  >
  </div>

  <!-- Content -->
  <div
    class="relative z-10 flex flex-col items-center gap-6 max-w-3xl px-4 py-14 text-center sm:py-20"
  >
    <!-- Title -->
    <h1
      class="font-display text-5xl font-normal italic text-white leading-tight sm:text-7xl lg:text-8xl drop-shadow-lg"
    >
      El Sabor de{" "}
      <span class="italic text-white">Nuestras<br />Raíces</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="text-cream text-lg leading-8 max-w-xl font-light sm:text-xl lg:text-2xl drop-shadow-md"
    >
      Café de especialidad en Marinilla, Antioquia.
      <br /> Un homenaje a la tierra, a la tradición y a cada grano cultivado con
      pasión.
    </p>

    <!-- Buttons -->
    <div class="flex flex-col w-full gap-4 pt-6 sm:w-auto sm:flex-row sm:gap-6">
      <a
        href="/menu"
        class="group flex items-center justify-center gap-3 bg-green-cafe text-white text-lg font-medium tracking-wide rounded-full px-10 py-4
               shadow-[0_0_20px_rgba(107,130,62,0.4)]
               hover:bg-[#5a6e34] hover:shadow-[0_0_30px_rgba(107,130,62,0.6)] transform hover:-translate-y-1 transition-all duration-300"
      >
        <svg
          class="w-5 h-5 group-hover:scale-110 transition-transform duration-300"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"
          ></path>
          <rect x="9" y="3" width="6" height="4" rx="1"></rect>
        </svg>
        Ver Menú
      </a>
      <a
        href="#contacto"
        class="flex items-center justify-center text-white text-lg font-medium tracking-wide rounded-full px-10 py-4
               bg-white/10 border-2 border-white/40 backdrop-blur-md
               hover:bg-white/20 hover:border-white/60 transform hover:-translate-y-1 transition-all duration-300 shadow-lg"
      >
        Visítanos
      </a>
    </div>
  </div>
</section>
