---
import { Image } from "astro:assets";
const menuItems = [
  {
    image: "/menu/cappuccino.png",
    name: "Cappuccino",
    description: "Espresso doble con leche texturizada cremosa.",
    price: "$8.500",
  },
  {
    image: "/menu/chemex.png",
    name: "Chemex",
    description: "Filtrado artesanal para un perfil limpio y aromático.",
    price: "$12.000",
  },
];
---

<section
  id="menu"
  class="bg-cream px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-20"
>
  <!-- Menu header -->
  <div class="text-center mb-10 sm:mb-12">
    <h2 class="font-display text-4xl font-normal text-stone-cafe mb-2">
      Menú Destacado
    </h2>
    <p class="text-base text-black font-extralight">
      Desde preparaciones clásicas hasta métodos de filtrado y repostería
      artesanal.
    </p>
  </div>

  <!-- Cards -->
  <div
    class="flex items-center justify-center mb-10 flex-col gap-6 sm:flex-row sm:gap-8"
  >
    {
      menuItems.map((item) => (
        <div class="bg-cream rounded-xl border border-green-cafe/40 overflow-hidden shadow-sm flex flex-col">
          <img
            src={item.image}
            alt={item.name}
            class="w-full h-[220px] object-cover sm:h-[260px] lg:h-[280px]"
          />
          <div class="p-5 flex flex-col gap-1 flex-1">
            <h3 class="font-display text-lg font-normal text-stone-cafe leading-7">
              {item.name}
            </h3>
            <p class="text-sm leading-5 text-black font-extralight">
              {item.description}
            </p>
            <div class="flex items-center justify-between pt-2 mt-auto">
              <span class="text-base text-green-cafe font-extralight">
                {item.price}
              </span>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- See full menu button -->
  <div class="text-center">
    <button
      class="border border-green-cafe bg-transparent rounded-lg px-6 py-2.5 text-sm text-stone-cafe font-extralight hover:bg-[#f9f8f5] transition-colors"
    >
      Ver Menú Completo
    </button>
  </div>
</section>
