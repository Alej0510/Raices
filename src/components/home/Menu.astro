---
import { Image } from "astro:assets";
const menuItems = [
  {
    image: "/menu/cappuccino.png",
    name: "Cappuccino",
    description: "Espresso doble con leche texturizada cremosa.",
    price: "$8.500",
  },
  {
    image: "/menu/chemex.png",
    name: "Chemex",
    description: "Filtrado artesanal para un perfil limpio y aromático.",
    price: "$12.000",
  },
];
---

<section
  id="menu"
  class="bg-cream px-4 py-10 sm:px-6 sm:py-14 lg:px-8 lg:py-20"
>
  <!-- Menu header -->
  <div class="text-center mb-14 sm:mb-16">
    <h2
      class="font-display text-4xl sm:text-5xl font-normal text-stone-cafe mb-4 tracking-tight"
    >
      Menú Destacado
    </h2>
    <p class="text-lg text-stone-mid font-light max-w-2xl mx-auto">
      Desde preparaciones clásicas hasta métodos de filtrado y repostería
      artesanal.
    </p>
  </div>

  <!-- Cards -->
  <div
    class="flex items-center justify-center mb-14 flex-col gap-8 sm:flex-row sm:gap-10 max-w-5xl mx-auto"
  >
    {
      menuItems.map((item) => (
        <div class="bg-white rounded-3xl border border-cream-border overflow-hidden shadow-sm hover:shadow-xl hover:border-green-cafe/30 transition-all duration-300 flex flex-col group transform hover:-translate-y-2 w-full sm:w-1/2">
          <div class="overflow-hidden relative">
            <img
              src={item.image}
              alt={item.name}
              class="w-full h-[240px] object-cover sm:h-[280px] lg:h-[320px] group-hover:scale-105 transition-transform duration-700 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-cafe/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          </div>
          <div class="p-8 flex flex-col gap-3 flex-1 bg-white relative z-10 shadow-sm border border-cream-border/50">
            <h3 class="font-display text-2xl font-normal text-stone-cafe">
              {item.name}
            </h3>
            <p class="text-base leading-relaxed text-stone-mid font-light">
              {item.description}
            </p>
            <div class="flex items-center justify-between pt-4 mt-auto border-t border-cream-border/60">
              <span class="text-lg text-green-cafe font-medium">
                {item.price}
              </span>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <!-- See full menu button -->
  <div class="text-center">
    <a
      href="/menu"
      class="inline-block border-2 border-green-cafe bg-transparent rounded-full px-8 py-3 text-base text-stone-cafe font-medium hover:bg-green-cafe hover:text-white transition-all duration-300 transform hover:-translate-y-0.5"
    >
      Ver Menú Completo
    </a>
  </div>
</section>
