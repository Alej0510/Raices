---
import { Leaf, CookingPot, Users } from "@lucide/astro";

const values = [
  {
    icon: Leaf,
    title: 'Origen Local',
    description:
      'Trabajamos directamente con caficultores de las veredas cercanas a Marinilla, asegurando un comercio justo y un producto fresco.',
  },
  {
    icon: CookingPot,
    title: 'Tostión Artesanal',
    description:
      'Cada lote se tuesta cuidadosamente para resaltar las notas únicas de chocolate y frutas de nuestra región.',
  },
  {
    icon: Users,
    title: 'Comunidad',
    description:
      'Raíces es más que una cafetería; es un punto de encuentro para compartir historias alrededor de una buena taza de café.',
  },
];
---

<section class="bg-warm border-t border-b border-cream-border px-4 py-16 sm:px-6 sm:py-24 lg:px-8 relative overflow-hidden">
  <!-- Decorative background circle -->
  <div class="absolute -top-40 -right-40 w-96 h-96 bg-cream-dark rounded-full blur-3xl opacity-50 pointer-events-none"></div>
  <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-cream-dark rounded-full blur-3xl opacity-50 pointer-events-none"></div>

  <div class="relative grid grid-cols-1 gap-8 max-w-[1280px] mx-auto md:grid-cols-3 md:gap-12 z-10">
    {values.map(item => (
      <div class="p-8 flex flex-col gap-5 text-center items-center md:items-start md:text-left bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all duration-300 border border-white hover:border-green-cafe/20 group transform hover:-translate-y-1">
        <!-- Icon -->
        <div class="w-16 h-16 rounded-2xl bg-cream flex items-center justify-center shrink-0 group-hover:bg-green-cafe/10 transition-colors duration-300">
          <item.icon class="w-7 h-7 text-green-cafe" />
        </div>
        <div class="space-y-3">
          <h3 class="font-display text-2xl font-normal text-stone-cafe">{item.title}</h3>
          <p class="text-base leading-relaxed text-stone-mid font-light">{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
