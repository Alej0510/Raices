---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Menú", href: "/menu" },
  { label: "Historia", href: "/#historia" },
  { label: "Contacto", href: "/#contacto" },
];
---

<header
  class="sticky top-0 z-50 bg-cream/90 backdrop-blur-md border-b border-cream-border/60 px-4 py-1 sm:px-6 lg:px-8"
  transition:persist="header"
>
  <div
    class="relative flex items-center justify-between h-14 w-full max-w-[1400px] mx-auto md:h-16"
  >
    <!-- Logo -->
    <a href="/" aria-label="Raíces Café - Inicio">
      <img
        src={"/logo.png"}
        alt="Raíces Café - Café de especialidad en Marinilla"
        class="w-[96px] object-contain sm:w-[110px]"
        width="110"
        height="43"
        transition:name="logo"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href;
          return (
            <a
              href={link.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "relative text-base font-light tracking-wide transition-colors duration-200 py-1 group",
                isActive
                  ? "text-stone-cafe"
                  : "text-stone-mid hover:text-stone-cafe",
              ]}
            >
              {link.label}
              <span
                class:list={[
                  "absolute left-0 -bottom-0.5 h-px bg-green-cafe transition-all duration-300",
                  isActive ? "w-full" : "w-0 group-hover:w-full",
                ]}
              />
            </a>
          );
        })
      }
    </nav>

    <!-- Mobile Nav -->
    <details class="md:hidden">
      <summary
        class="list-none cursor-pointer rounded-md p-2 text-stone-cafe hover:bg-black/5 transition-colors"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </summary>
      <nav
        class="absolute right-0 top-12 w-52 rounded-xl border border-cream-border bg-cream shadow-lg p-3 flex flex-col gap-2"
      >
        {
          navLinks.map((link) => {
            const isActive = currentPath === link.href;
            return (
              <a
                href={link.href}
                aria-current={isActive ? "page" : undefined}
                class:list={[
                  "rounded-md px-3 py-2 text-base font-extralight transition-colors duration-200",
                  isActive
                    ? "text-stone-cafe"
                    : "text-stone-mid hover:bg-black/5 hover:text-stone-cafe",
                ]}
              >
                {link.label}
              </a>
            );
          })
        }
      </nav>
    </details>
  </div>
</header>

<script>
  function updateHeaderActiveState() {
    const path = window.location.pathname;
    const links = document.querySelectorAll("header nav a");

    links.forEach((link) => {
      const href = link.getAttribute("href");
      const isActive = href === path;
      const isDesktop = link.closest("nav.hidden.md\\:flex") !== null;
      const underline = link.querySelector("span.absolute");

      if (isActive) {
        link.setAttribute("aria-current", "page");
        link.classList.remove("text-stone-mid", "hover:text-stone-cafe", "hover:bg-black/5");
        link.classList.add("text-stone-cafe");
        if (underline) {
          underline.classList.remove("w-0");
          underline.classList.add("w-full");
        }
      } else {
        link.removeAttribute("aria-current");
        link.classList.remove("text-stone-cafe");
        if (isDesktop) {
          link.classList.add("text-stone-mid", "hover:text-stone-cafe");
        } else {
          link.classList.add("text-stone-mid", "hover:bg-black/5", "hover:text-stone-cafe");
        }
        if (underline) {
          underline.classList.remove("w-full");
          underline.classList.add("w-0");
        }
      }
    });
  }

  document.addEventListener("astro:after-swap", updateHeaderActiveState);
</script>
